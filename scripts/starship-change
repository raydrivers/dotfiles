#!/bin/bash

set -e

DOTFILES_DIR="${DOTFILES_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
. "$DOTFILES_DIR/scripts/lib/log.sh"

CONFIG_PATH="$HOME/.config/starship.toml"

if [[ $# -eq 0 ]]; then
    echo "Usage: starship-change <path-to-config-file>"
    echo "Example: starship-change ~/.config/starship/simple.toml"
    echo "         starship-change /path/to/my-starship.toml"
    exit 1
fi

config_path="$1"

# Check if config exists
if [[ ! -f "$config_path" ]]; then
    log_error "Configuration file not found at $config_path"
    exit 1
fi

# Create backup of existing config if it exists and is not a symlink
if [[ -f "$CONFIG_PATH" && ! -L "$CONFIG_PATH" ]]; then
    log_warn "Backing up existing starship.toml"
    mv "$CONFIG_PATH" "${CONFIG_PATH}.backup.$(date +%Y%m%d_%H%M%S)"
fi

# Remove existing symlink if it exists
if [[ -L "$CONFIG_PATH" ]]; then
    rm "$CONFIG_PATH"
fi

# Create new symlink
ln -sf "$config_path" "$CONFIG_PATH"

log_ok "Switched to starship configuration: $config_path"
log_warn "Restart your terminal or run 'exec \$SHELL' for changes to take effect"